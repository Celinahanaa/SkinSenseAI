# =============================================
# SkinSenseAI - Backend Environment Variables
# Salin file ini menjadi .env dan isi nilainya
# =============================================

# === Database (PostgreSQL) ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=skinsense_db

# Full DATABASE_URL (alternatif, dipakai Railway)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/skinsense_db

# === Authentication ===
JWT_SECRET=ganti_dengan_string_acak_yang_panjang_dan_aman

# === Cloudinary (Upload Gambar Avatar) ===
# Daftar di https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# === AI Service ===
# URL ke layanan FastAPI model ML (skin analysis)
# Contoh: https://skinsense.yourdomain.my.id
AI_SERVICE_URL=http://localhost:8000

# === Server ===
PORT=3000
